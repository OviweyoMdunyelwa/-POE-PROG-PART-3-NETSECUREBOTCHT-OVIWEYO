<Window x:Class="Net_Bot_App.ChatBotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity ChatBot" Height="650" Width="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Side Menu -->
        <Grid x:Name="SideMenu"
              Background="Purple"
              Width="250"
              Visibility="Collapsed"
              Grid.RowSpan="2">
            <StackPanel Margin="10">
                <TextBlock Text="Saved Chats" Foreground="White" FontSize="18" Margin="0,0,0,10"/>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SavedChatsList"/>
                </ScrollViewer>
                <Button Content="Start New Chat"
                        Click="NewChat_Click"
                        Background="#FFD063FB"
                        Foreground="White"
                        Margin="0,10,0,0"/>
                <!-- Topic Buttons -->
                <TextBlock Text="Topics" Foreground="White" FontSize="14" Margin="0,15,0,5"/>

                <Button Content="🔐 Phishing"
        Click="Topic_Phishing_Click"
        Background="#FFD063FB"
        Foreground="White"
        Margin="0,4,0,0"
        Padding="8,6"
        BorderThickness="0"/>

                <Button Content="🔑 Passwords"
        Click="Topic_Password_Click"
        Background="#FFD063FB"
        Foreground="White"
        Margin="0,4,0,0"
        Padding="8,6"
        BorderThickness="0"/>

                <Button Content="🛡️ Malware"
        Click="Topic_Malware_Click"
        Background="#FFD063FB"
        Foreground="White"
        Margin="0,4,0,0"
        Padding="8,6"
        BorderThickness="0"/>

                <Button Content="🌐 Safe Browsing"
        Click="Topic_Browsing_Click"
        Background="#FFD063FB"
        Foreground="White"
        Margin="0,4,0,0"
        Padding="8,6"
        BorderThickness="0"/>

                <!-- Save Chat Button -->
                <Button Content="💾 Save Chat"
        Click="SaveChat_Click"
        Background="#FFD063FB"
        Foreground="White"
        Margin="0,15,0,0"
        Padding="8,6"
        BorderThickness="0"/>

                <!-- Quiz Button -->
                <Button Content="🎮 Start Quiz"
        Click="StartQuiz_Click"
        Background="#FFD063FB"
        Foreground="White"
        Margin="0,8,0,0"
        Padding="8,6"
        BorderThickness="0"/>
                <!-- Task Assistant Button -->
                <Button Content="📋 Task Assistant"
        Click="TaskAssistantButton_Click"
        Background="#FFD063FB"
        Foreground="White"
        Margin="0,8,0,0"
        Padding="8,6"
        BorderThickness="0"/>
            </StackPanel>
        </Grid>

        <!-- Hamburger Button -->
        <Button x:Name="MenuButton"
        Width="40" Height="40"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Click="ToggleMenu_Click"
        Grid.Column="1"
        Grid.Row="0"
        Panel.ZIndex="10"
        Background="Purple"
        BorderThickness="0"
        ToolTip="Open Menu">
            <StackPanel Orientation="Vertical" Margin="4">
                <Rectangle Height="4" Fill="Purple" Margin="0,3"/>
                <Rectangle Height="4" Fill="Purple" Margin="0,3"/>
                <Rectangle Height="4" Fill="Purple" Margin="0,3"/>
                <Rectangle Height="4" Fill="Purple" Margin="0,3"/>
            </StackPanel>
        </Button>

        <!-- Chat messages -->
        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="0" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,45,0,0">
            <StackPanel x:Name="ChatPanel"
                        Margin="10"
                        VerticalAlignment="Bottom"/>
        </ScrollViewer>

        
        <!-- Typing Indicator -->
        <StackPanel x:Name="TypingIndicator"
            Grid.Row="1" Grid.Column="1"
            Orientation="Horizontal"
            Visibility="Collapsed"
            Margin="10,5,10,0"
            VerticalAlignment="Center">

            <!-- Glowing animated dots -->
            <Border Width="14" Height="14" CornerRadius="7" Background="#FFD063FB" Margin="3,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.1" Duration="0:0:0.5"
                                                 AutoReverse="True" BeginTime="0:0:0"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <Border Width="14" Height="14" CornerRadius="7" Background="#FFD063FB" Margin="3,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.1" Duration="0:0:0.5"
                                                 AutoReverse="True" BeginTime="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <Border Width="14" Height="14" CornerRadius="7" Background="#FFD063FB" Margin="3,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.1" Duration="0:0:0.5"
                                                 AutoReverse="True" BeginTime="0:0:0.4"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

        </StackPanel>

        <!-- Input bubble -->
        <Border Grid.Row="1" Grid.Column="1"
                Margin="10"
                CornerRadius="12"
                BorderBrush="Purple"
                BorderThickness="2"
                Background="White">
            <DockPanel LastChildFill="True">
                <Button Content="➤"
                        FontSize="16"
                        Width="32"
                        Height="32"
                        Background="Purple"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SendButton_Click"
                        Margin="4"
                        Cursor="Hand"
                        ToolTip="Send message"
                        DockPanel.Dock="Right"/>
                <TextBox x:Name="ChatInput"
                         TextWrapping="Wrap"
                         FontSize="16"
                         Padding="8"
                         BorderThickness="0"
                         Background="Transparent"
                         KeyDown="ChatInput_KeyDown"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
