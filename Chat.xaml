<Window x:Class="Net_Bot_App.Chat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Net_Bot_App"
        mc:Ignorable="d"
        Title="Chat" Height="600" Width="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="129*"/>
            <ColumnDefinition Width="871*"/>
        </Grid.ColumnDefinitions>

        <Grid.Background>
            <ImageBrush TileMode="None"/>
        </Grid.Background>
        <Image HorizontalAlignment="Left" Height="199" Margin="272,101,0,0" VerticalAlignment="Top" Width="275" Source="/ChatGPT Image Apr 28, 2026, 11_41_04 AM.png" RenderTransformOrigin="0.865,0.541" Grid.Column="1"/>
        <Label Content="NetSecureBotChat" HorizontalAlignment="Left" Margin="199,257,0,0" VerticalAlignment="Top" Foreground="#FF080303" FontFamily="Yu Gothic Light" FontSize="48" RenderTransformOrigin="0.5,0.5" Height="86" Width="408" Grid.Column="1"/>
        <Image HorizontalAlignment="Left" Height="100" Margin="696,54,0,0" VerticalAlignment="Top" Width="100" Grid.Column="1"/>
        <Image HorizontalAlignment="Left" Height="189" Margin="587,0,0,0" VerticalAlignment="Top" Width="344" Source="/ChatGPT Image Apr 28, 2026, 01_27_39 PM.png" Grid.Column="1"/>
        <Image HorizontalAlignment="Left" Height="189" Margin="-1,393,0,0" VerticalAlignment="Top" Width="344" Source="/ChatGPT Image Apr 28, 2026, 01_27_39 PM.png" RenderTransformOrigin="0.5,0.5" Grid.ColumnSpan="2">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-179.978"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Label Content="here to help you stay secure" HorizontalAlignment="Left" Margin="12,20,0,0" VerticalAlignment="Top" Foreground="#FF4F0891" FontSize="16" RenderTransformOrigin="0.171,0.089" FontFamily="Bahnschrift Light" Width="312" Grid.ColumnSpan="2">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.092"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Label Content="here to help you stay protected" HorizontalAlignment="Left" Margin="131,521,0,0" VerticalAlignment="Top" Foreground="#FF4F0891" FontSize="16" RenderTransformOrigin="0.171,0.089" FontFamily="Bahnschrift Light" Width="312" Grid.Column="1">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.244"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Label Content="here to help you stay safe" HorizontalAlignment="Left" Margin="-5,239,0,0" VerticalAlignment="Top" Foreground="#FF4F0891" FontSize="16" RenderTransformOrigin="0.171,0.089" FontFamily="Bahnschrift Light" Width="312" Grid.ColumnSpan="2">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="90.563"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Border HorizontalAlignment="Left" Margin="190,343,0,0" VerticalAlignment="Top" Width="417" Height="42" Grid.Column="1" >
            <TextBox 
    x:Name="ChatInput"            
    TextWrapping="Wrap" 
    FontSize="18" 
    TextChanged="TextBox_TextChanged"
    Padding="8"
    BorderThickness="2"
    BorderBrush="Purple" Margin="0,10,0,-30">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border 
                            CornerRadius="12" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            Background="{TemplateBinding Background}">
                                        <DockPanel LastChildFill="True">
                                            <!-- Send button docked right -->
                                            <Button 
                                    Content="➤" 
                                    FontSize="16"
                                    Width="28"
                                    Height="28"
                                    Background="Purple" 
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="SendButton_Click"
                                    Margin="4"
                                    Cursor="Hand"
                                    ToolTip="Send message"
                                    DockPanel.Dock="Right"/>


                                            <!-- Text content fills remaining space -->
                                            <ScrollViewer x:Name="PART_ContentHost" />
                                        </DockPanel>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <!-- Glow effect when focused -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="Purple"/>
                                <Setter Property="BorderThickness" Value="3"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect 
                                Color="Purple" 
                                BlurRadius="15" 
                                ShadowDepth="0" 
                                Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>


        </Border>
        <Label Content="hello!  what is your name ?" HorizontalAlignment="Left" Margin="197,326,0,0" VerticalAlignment="Top" Foreground="#FF4F0891" FontSize="20" RenderTransformOrigin="0.171,0.089" FontFamily="Arial" Width="312" Grid.Column="1">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.244"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>

    </Grid>

</Window>
