<Window x:Class="Net_Bot_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Net_Bot_App"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1000">
    <Grid RenderTransformOrigin="0.497,0.522">
        <Grid.Background>
            <RadialGradientBrush>
                <RadialGradientBrush.RelativeTransform>
                    <TransformGroup>
                        <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                        <SkewTransform CenterX="0.5" CenterY="0.5"/>
                        <RotateTransform Angle="5.315" CenterX="0.5" CenterY="0.5"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </RadialGradientBrush.RelativeTransform>
                <GradientStop Color="#FFD063FB" Offset="0.05"/>
                <GradientStop Color="#FF73119A" Offset="0.947"/>
            </RadialGradientBrush>
        </Grid.Background>
        <Image HorizontalAlignment="Center"
       Height="279"
       Margin="0,114,0,0"
       VerticalAlignment="Top"
       Width="276"
       Source="/ChatGPT Image Apr 28, 2026, 11_41_04 AM.png"
       RenderTransformOrigin="0.865,0.541">

            <!-- 🖤 Realistic floating shadow -->
            <Image.Effect>
                <DropShadowEffect Color="Black"
                          BlurRadius="40"
                          ShadowDepth="8"
                          Direction="270"
                          Opacity="0.6"/>
            </Image.Effect>

        </Image>
        <Label Content="NetSecureBotChat" HorizontalAlignment="Left" Margin="311,330,0,0" VerticalAlignment="Top" Foreground="White" FontFamily="Yu Gothic Light" FontSize="48" RenderTransformOrigin="0.5,0.5" Height="80" Width="395"/>


        <Button Content="Continue "
        HorizontalAlignment="Left"
        Margin="416,442,0,0"
        VerticalAlignment="Top"
        Height="45"
        Width="202"
        Click="Button_Click"
        Foreground="White"
        FontWeight="Bold"
        BorderThickness="0">

            <!-- 🔥 Background Gradient -->
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E9D5FF" Offset="0"/>
                    <GradientStop Color="#A855F7" Offset="0.4"/>
                    <GradientStop Color="#6B21A8" Offset="0.8"/>
                    <GradientStop Color="#FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>

            <!-- 🔥 BIG glow -->
            <Button.Effect>
                <DropShadowEffect Color="#C084FC"
                          BlurRadius="35"
                          ShadowDepth="0"
                          Opacity="1"/>
            </Button.Effect>

            <!-- 🔥 Custom Template -->
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>

                        <!-- Outer glow border -->
                        <Border CornerRadius="25"
                        Background="{TemplateBinding Background}">

                            <Grid>

                                <!-- ✨ Mirror shine layer -->
                                <Rectangle RadiusX="25" RadiusY="25" Opacity="0.35">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="0.6"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <!-- Content -->
                                <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 🚀 Hover = MORE WOW -->
                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#E9D5FF"
                                              BlurRadius="50"
                                              ShadowDepth="0"
                                              Opacity="1"/>
                                </Setter.Value>
                            </Setter>

                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>

        </Button>
        <Image HorizontalAlignment="Left" Height="174" Margin="806,388,0,0" VerticalAlignment="Top" Width="247" Source="/ChatGPT Image Apr 28, 2026, 01_48_54 PM.png" RenderTransformOrigin="0.363,0.475">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-90.587"/>
                    <TranslateTransform X="36.204" Y="37.685"/>
                </TransformGroup>
            </Image.RenderTransform>
            <Image.OpacityMask>
                <ImageBrush ImageSource="/ChatGPT Image Apr 28, 2026, 01_48_54 PM.png"/>
            </Image.OpacityMask>
        </Image>
        <Label Content="here to help you stay protected" HorizontalAlignment="Left" Margin="-20,360,0,0" VerticalAlignment="Top" Foreground="White" FontSize="16" RenderTransformOrigin="0.171,0.089" FontFamily="Bahnschrift Light" Width="312">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="90.485"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Image HorizontalAlignment="Left" Height="100" Margin="43,56,0,0" VerticalAlignment="Top" Width="100"/>
        <Label Content="Label" HorizontalAlignment="Left" Margin="1089,370,0,0" VerticalAlignment="Top"/>
        <Label Content="here to help you stay secure" HorizontalAlignment="Left" Margin="722,3,0,0" VerticalAlignment="Top" Foreground="White" FontSize="16" RenderTransformOrigin="0.171,0.089" FontFamily="Bahnschrift Light" Width="312">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.092"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Image HorizontalAlignment="Left" Height="159" Margin="-52,29,0,0" VerticalAlignment="Top" Width="228" Source="/ChatGPT Image Apr 28, 2026, 02_03_22 PM.png" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="89.577"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Label Content="here to help you stay safe" HorizontalAlignment="Left" Margin="641,536,0,0" VerticalAlignment="Top" Foreground="White" FontSize="16" RenderTransformOrigin="0.171,0.089" FontFamily="Bahnschrift Light" Width="312">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.114"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
    </Grid>
</Window>
