<Window x:Class="Net_Bot_App.QuizGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Quiz" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FF73119A">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="NetBotChat Quiz"
                   Foreground="White" FontSize="28" FontWeight="Bold"
                   HorizontalAlignment="Left" Margin="20,10,0,5"/>

        <!-- Score + Question Counter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBlock x:Name="QuestionCounter"
                       Text="Question 1 of 12"
                       Foreground="White" FontSize="16" Margin="0,0,20,0"/>
            <TextBlock x:Name="ScoreDisplay"
                       Text="Score: 0"
                       Foreground="#A855F7" FontSize="16" FontWeight="Bold"/>
        </StackPanel>

        <!-- Progress Bar -->
        <ProgressBar x:Name="QuizProgress"
                     Grid.Row="2"
                     Height="10" Minimum="0" Maximum="12" Value="1"
                     Foreground="#FFD063FB" Background="#FF73119A"
                     Margin="0,0,0,15"/>

        <!-- Question Box -->
        <Border Grid.Row="3" Background="#FFD063FB"
                CornerRadius="15" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock x:Name="QuestionText"
                           Text="Loading question..."
                           Foreground="White" FontSize="18"
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <!-- Answer Buttons -->
                <Button x:Name="BtnA" Click="Answer_Click" Tag="A"
                        Margin="0,5" Padding="12,10"
                        Background="#6B21A8" Foreground="White"
                        FontSize="15" BorderThickness="0"
                        HorizontalContentAlignment="Left"/>
                <Button x:Name="BtnB" Click="Answer_Click" Tag="B"
                        Margin="0,5" Padding="12,10"
                        Background="#6B21A8" Foreground="White"
                        FontSize="15" BorderThickness="0"
                        HorizontalContentAlignment="Left"/>
                <Button x:Name="BtnC" Click="Answer_Click" Tag="C"
                        Margin="0,5" Padding="12,10"
                        Background="#6B21A8" Foreground="White"
                        FontSize="15" BorderThickness="0"
                        HorizontalContentAlignment="Left"/>
                <Button x:Name="BtnD" Click="Answer_Click" Tag="D"
                        Margin="0,5" Padding="12,10"
                        Background="#6B21A8" Foreground="White"
                        FontSize="15" BorderThickness="0"
                        HorizontalContentAlignment="Left"/>

                <!-- True/False (shown for T/F questions) -->
                <StackPanel x:Name="TrueFalsePanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed" Margin="0,10,0,0">
                    <Button Content="✅ True" Tag="True"
                            Click="Answer_Click"
                            Background="#6B21A8" Foreground="White"
                            FontSize="15" BorderThickness="0"
                            Padding="30,10" Margin="10,0"/>
                    <Button Content="❌ False" Tag="False"
                            Click="Answer_Click"
                            Background="#6B21A8" Foreground="White"
                            FontSize="15" BorderThickness="0"
                            Padding="30,10" Margin="10,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Feedback Box -->
        <Border x:Name="FeedbackBox" Grid.Row="4"
                Background="#3B0764" CornerRadius="12"
                Padding="15" Margin="0,0,0,10"
                Visibility="Collapsed">
            <TextBlock x:Name="FeedbackText"
                       Foreground="White" FontSize="15"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Next / Finish Button -->
        <Button x:Name="NextButton" Grid.Row="5"
                Content="Next Question ➤"
                Click="Next_Click"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                Padding="20,10" FontSize="16"
                FontWeight="Bold" BorderThickness="0"
                Foreground="White">
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E9D5FF" Offset="0"/>
                    <GradientStop Color="#A855F7" Offset="0.4"/>
                    <GradientStop Color="#6B21A8" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
    </Grid>
</Window>